{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "C:/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": [
                "-S", ".",
                "-B", "build",
                "-G", "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_PREFIX_PATH=C:/Qt/6.9.1/mingw_64",
                "-DCMAKE_MAKE_PROGRAM=C:/Qt/Tools/Ninja/ninja.exe",
                "-DCMAKE_C_COMPILER=C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=C:/Qt/Tools/mingw1310_64/bin/g++.exe"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "C:/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": [
                "--build", "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "dependsOn": "CMake: Configure"
        },
        {
            "label": "Run Application",
            "type": "process",
            "command": "${workspaceFolder}/build/rm_test.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:/Qt/6.9.1/mingw_64/bin;${env:PATH}"
                }
            },
            "dependsOn": "CMake: Build",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}