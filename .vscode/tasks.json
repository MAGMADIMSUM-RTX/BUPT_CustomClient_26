{
    "version": "2.0.0",
    "tasks": [
        // --- Full Version (Developer/Debug) ---
        {
            "label": "Config: Full (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build_full",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DBUILD_USER_VERSION=OFF",
                "-DCMAKE_PREFIX_PATH=/home/user/Qt/6.10.1/gcc_64",
                "-DQt6_DIR=/home/user/Qt/6.10.1/gcc_64/lib/cmake/Qt6"
            ],
            "group": "build",
            "detail": "Configure Full Version (Debug)"
        },
        {
            "label": "Build: Full (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_full"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "dependsOn": "Config: Full (Debug)",
            "detail": "Build Full Version (Debug)"
        },

        // --- User Version (Release/Simplified) ---
        {
            "label": "Config: User (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", ".",
                "-B", "build_user",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_USER_VERSION=ON",
                "-DCMAKE_PREFIX_PATH=/home/user/Qt/6.10.1/gcc_64",
                "-DQt6_DIR=/home/user/Qt/6.10.1/gcc_64/lib/cmake/Qt6"
            ],
            "group": "build",
            "detail": "Configure User Version (Release)"
        },
        {
            "label": "Build: User (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build_user"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "dependsOn": "Config: User (Release)",
            "detail": "Build User Version (Release)"
        },

        // --- Run Commands ---
        {
            "label": "Run: Full Version",
            "type": "process",
            "command": "${workspaceFolder}/build_full/CustomClient",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build: Full (Debug)",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run: User Version",
            "type": "process",
            "command": "${workspaceFolder}/build_user/CustomClient",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Build: User (Release)",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
